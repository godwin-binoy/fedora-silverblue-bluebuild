# Enable runtime power-saving for all PCI and USB bridges
ACTION=="add", SUBSYSTEM=="pci", ATTR{power/control}="auto"
ACTION=="add", SUBSYSTEM=="usb", TEST=="power/control", ATTR{power/control}="auto"

# Force immediate autosuspend on cameras (Chicony) and USB Bluetooth receivers
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="04f2", ATTR{power/autosuspend}="1", ATTR{power/control}="auto"
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="0bda", ATTR{power/autosuspend}="1", ATTR{power/control}="auto"

# Force ASPM and power saving on Realtek wireless card
ACTION=="add", SUBSYSTEM=="pci", ATTR{vendor}=="0x10ec", ATTR{device}=="0xb852", ATTR{power/control}="auto"

# Enable NVMe APST and storage device autosuspend
ACTION=="add", SUBSYSTEM=="block", KERNEL=="nvme*", ATTR{queue/rotational}=="0", ATTR{queue/scheduler}="none"
ACTION=="add", SUBSYSTEM=="pci", DRIVER=="nvme", ATTR{power/control}="auto"
