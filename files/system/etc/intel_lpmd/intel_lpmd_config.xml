<?xml version="1.0" encoding="utf-8"?>
<Configuration>
    <!-- Leave empty to auto-detect the 2 LP E-cores on the SoC tile -->
    <lp_mode_cpus></lp_mode_cpus>
    <Mode>0</Mode> <!-- Use cgroups v2 mapping to restrict active slices to LP E-cores -->
    <PerformanceDef>-1</PerformanceDef>
    <BalancedDef>0</BalancedDef>
    <PowersaverDef>1</PowersaverDef>
    <HfiLpmEnable>1</HfiLpmEnable>
    <HfiSuvEnable>1</HfiSuvEnable>
    <util_entry_threshold>40</util_entry_threshold> <!-- Bound background tasks when CPU is under 40% -->
    <util_exit_threshold>85</util_exit_threshold>  <!-- Release constraints when load exceeds 85% -->
</Configuration>