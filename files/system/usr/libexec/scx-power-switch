#!/bin/bash
set -euo pipefail

# Discover AC adapter state across various vendor interfaces (AC0, ADP0, ACAD, etc.)
ONLINE=1
for psu in /sys/class/power_supply/*; do
    if [ -f "$psu/type" ] && [ "$(cat "$psu/type")" = "Mains" ]; then
        if [ -f "$psu/online" ]; then
            ONLINE=$(cat "$psu/online")
            break
        fi
    fi
done

# Securely toggle sched-ext scheduler with no-block flags to prevent systemd deadlocks
if systemctl is-enabled scx_loader.service >/dev/null 2>&1; then
    if [ "$ONLINE" -eq 1 ] && [ -d "/sys/kernel/sched_ext" ]; then
        echo "AC Connected: Activating sched-ext performance loop."
        systemctl start --no-block scx_loader.service || true
    else
        echo "Battery Power or sched-ext unsupported: Suspending sched-ext."
        systemctl stop --no-block scx_loader.service || true
    fi
fi

# Dynamic Energy Performance Preference (EPP) Toggling
EPP_PATH="/sys/devices/system/cpu/cpu0/cpufreq/energy_performance_preference"
if [ -f "$EPP_PATH" ]; then
    if [ "$ONLINE" -eq 1 ]; then
        echo "AC Connected: Setting EPP to balance_performance."
        echo "balance_performance" | tee /sys/devices/system/cpu/cpu*/cpufreq/energy_performance_preference >/dev/null || true
    else
        echo "Battery Power: Setting EPP to power."
        echo "power" | tee /sys/devices/system/cpu/cpu*/cpufreq/energy_performance_preference >/dev/null || true
    fi
fi
